server <- function(input, output, session) {
  current_page <- reactiveVal("dashboard")
  refresh_trigger <- reactiveVal(Sys.time())

  objetivos_df <- reactive({ refresh_trigger(); get_objetivos() })
  krs_df <- reactive({ refresh_trigger(); get_krs() })

  output$sidebar_obj_count <- renderText(nrow(objetivos_df()))
  output$sidebar_kr_count <- renderText(nrow(krs_df()))

  set_page <- function(page) {
    current_page(page)
    session$sendCustomMessage("active_nav", page)
  }

  observeEvent(input$go_dashboard, set_page("dashboard"))
  observeEvent(input$go_input, set_page("input"))
  observeEvent(input$go_registros, set_page("registros"))

  output$page_title <- renderText({
    switch(current_page(), dashboard = "Dashboard", input = "Coletar Dados", registros = "Registros")
  })
  output$page_subtitle <- renderText({
    switch(current_page(),
      dashboard = "Monitoramento executivo dos OKRs da Mirai.",
      input = "Formulário integrado para alimentar a base e o BI.",
      registros = "Histórico operacional e dados recentes."
    )
  })

  output$page_content <- renderUI({
    switch(current_page(),
      dashboard = dashboard_module_ui("dash"),
      input = input_module_ui("inp"),
      registros = dashboard_records_ui("records")
    )
  })

  dashboard_module_server("dash", refresh_trigger)
  input_module_server("inp", refresh_trigger)
  dashboard_records_server("records", refresh_trigger)

  observe({
    invalidateLater(60000, session)
    refresh_trigger(Sys.time())
  })

  session$onFlushed(function() {
    session$sendCustomMessage("active_nav", "dashboard")
  }, once = TRUE)
}

shinyApp(ui, server)
